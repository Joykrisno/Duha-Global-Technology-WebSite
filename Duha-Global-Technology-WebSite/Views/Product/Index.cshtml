@section Scripts {
    <script>
        // ===== FILTER LOGIC =====
        const tabs = document.querySelectorAll('.filter-tab');
        const items = document.querySelectorAll('.product-item');
        const resultsCount = document.getElementById('resultsCount');
        const emptyState = document.getElementById('emptyState');
        const searchInput = document.getElementById('productSearch');
        const sortSelect = document.getElementById('sortSelect');

        let currentFilter = 'all';
        let currentSearch = '';
        let currentSort = '';

        function applyFilters() {
            let visible = 0;
            items.forEach(item => {
                const cat = item.dataset.category;
                const nameEl = item.querySelector('.product-name');
                const descEl = item.querySelector('.product-desc');
                const name = nameEl ? nameEl.textContent.toLowerCase() : '';
                const desc = descEl ? descEl.textContent.toLowerCase() : '';

                const catMatch = (currentFilter === 'all') || (cat === currentFilter);
                const searchMatch = (currentSearch === '') || name.includes(currentSearch) || desc.includes(currentSearch);

                if (catMatch && searchMatch) {
                    item.style.display = '';
                    visible++;
                } else {
                    item.style.display = 'none';
                }
            });

            resultsCount.textContent = `Showing ${visible} product${visible !== 1 ? 's' : ''}`;
            emptyState.style.display = visible === 0 ? 'block' : 'none';
        }

        tabs.forEach(tab => {
            tab.addEventListener('click', () => {
                tabs.forEach(t => t.classList.remove('active'));
                tab.classList.add('active');
                currentFilter = tab.dataset.filter;
                applyFilters();
            });
        });

        searchInput.addEventListener('input', () => {
            currentSearch = searchInput.value.toLowerCase().trim();
            applyFilters();
        });

        // ===== SORT LOGIC =====
        sortSelect.addEventListener('change', () => {
            currentSort = sortSelect.value;
            const grid = document.getElementById('productGrid');
            const itemsArr = [...grid.querySelectorAll('.product-item')];

            itemsArr.sort((a, b) => {
                if (currentSort === 'price-low') return +a.dataset.price - +b.dataset.price;
                if (currentSort === 'price-high') return +b.dataset.price - +a.dataset.price;
                if (currentSort === 'rating') return +b.dataset.rating - +a.dataset.rating;
                return 0;
            });
            itemsArr.forEach(el => grid.appendChild(el));
        });

        // ===== WISHLIST TOGGLE =====
        document.querySelectorAll('.product-wishlist').forEach(btn => {
            btn.addEventListener('click', function () {
                const icon = this.querySelector('i');
                icon.classList.toggle('fas');
                icon.classList.toggle('far');
                this.style.color = icon.classList.contains('fas') ? '#e63946' : '#ccc';
            });
        });

        // ===== ADD TO CART FEEDBACK =====
        document.querySelectorAll('.btn-add-cart').forEach(btn => {
            btn.addEventListener('click', function () {
                const original = this.innerHTML;
                this.innerHTML = '<i class="fas fa-check me-1"></i>Added!';
                this.style.background = '#198754';
                setTimeout(() => {
                    this.innerHTML = original;
                    this.style.background = '';
                }, 1500);
            });
        });

        function resetFilters() {
            currentFilter = 'all';
            currentSearch = '';
            searchInput.value = '';
            tabs.forEach(t => t.classList.remove('active'));
            tabs[0].classList.add('active');
            applyFilters();
        }
    </script>
}
