@{
    ViewData["Title"] = "Product";
 
}


<!-- PRODUCTS HERO -->
<section class="products-hero">
    <div class="container position-relative" style="z-index:5;">
        <div class="row align-items-center g-4">
            <div class="col-lg-6" data-aos="fade-up">
                <span class="badge bg-white bg-opacity-60 text-primary px-4 py-2 rounded-pill mb-3 d-inline-block">
                    <i class="fas fa-box-open me-2"></i> Our Product Catalog
                </span>
                <h1 class="page-title">Premium Products<br>for Every Need</h1>
                <p class="fs-5 text-secondary mt-3">Chargers · Cables · Headphones · Pendrives · CCTV · Electric Items</p>
            </div>
            <div class="col-lg-6" data-aos="fade-left">
                <div class="search-wrapper ms-lg-auto">
                    <input type="text" id="productSearch" placeholder="Search products (e.g. GaN charger, headphones...)" />
                    <span class="search-icon"><i class="fas fa-search"></i></span>
                </div>
            </div>
        </div>
    </div>
</section>

<!-- STATS STRIP -->
<div class="stats-strip">
    <div class="container">
        <div class="row g-0">
            <div class="col stat-item">
                <div class="stat-num">120+</div>
                <div class="stat-label">Products</div>
            </div>
            <div class="col stat-item">
                <div class="stat-num">12+</div>
                <div class="stat-label">Countries</div>
            </div>
            <div class="col stat-item">
                <div class="stat-num">50K+</div>
                <div class="stat-label">Happy Customers</div>
            </div>
            <div class="col stat-item">
                <div class="stat-num">2yr</div>
                <div class="stat-label">Warranty</div>
            </div>
        </div>
    </div>
</div>

<!-- MAIN PRODUCT SECTION -->
<section class="container py-5">

    <!-- FILTER TABS -->
    <div class="filter-tabs" data-aos="fade-up" id="filterTabs">
        <button class="filter-tab active" data-filter="all"><i class="fas fa-th"></i>All Products</button>
        <button class="filter-tab" data-filter="charger"><i class="fas fa-charging-station"></i>Chargers</button>
        <button class="filter-tab" data-filter="cable"><i class="fas fa-plug"></i>Cables</button>
        <button class="filter-tab" data-filter="audio"><i class="fas fa-headphones"></i>Headphones</button>
        <button class="filter-tab" data-filter="storage"><i class="fas fa-hdd"></i>Pendrives & Storage</button>
        <button class="filter-tab" data-filter="cctv"><i class="fas fa-video"></i>CCTV</button>
        <button class="filter-tab" data-filter="electric"><i class="fas fa-bolt"></i>Electric Items</button>
        <button class="filter-tab" data-filter="powerbank"><i class="fas fa-battery-three-quarters"></i>Power Banks</button>
    </div>

    <!-- RESULTS BAR -->
    <div class="results-bar" data-aos="fade-up">
        <span class="results-count" id="resultsCount"><i class="fas fa-layer-group me-1"></i> Showing all 24 products</span>
        <select class="sort-select" id="sortSelect">
            <option value="">Sort: Featured</option>
            <option value="price-low">Price: Low to High</option>
            <option value="price-high">Price: High to Low</option>
            <option value="rating">Top Rated</option>
        </select>
    </div>

    <!-- PROMO BANNER -->
    <div class="promo-banner" data-aos="fade-up">
        <div class="row align-items-center">
            <div class="col-md-8">
                <span class="badge bg-warning text-dark mb-2">Limited Time</span>
                <h4 class="fw-bold mb-1">Buy 3 Get 15% OFF on all Chargers & Cables!</h4>
                <p class="mb-0 opacity-75">Use code <strong>DUHA15</strong> at checkout. Valid till 30 April 2026.</p>
            </div>
            <div class="col-md-4 text-md-end mt-3 mt-md-0">
                <a href="#chargers" class="btn btn-light fw-bold px-4 py-2 rounded-pill">Shop Now <i class="fas fa-arrow-right ms-1"></i></a>
            </div>
        </div>
    </div>

