@{
    ViewData["Title"] = "Home";
    Layout = "~/Views/Shared/_Layout.cshtml";
}


<!-- HERO (Home) -->
<section id="home" class="hero-duha position-relative">
    <div style="position:absolute; width:600px; height:600px; background:radial-gradient(circle, #c2ddff20, transparent 75%); top:-100px; right:-100px; border-radius:50%;"></div>
    <div class="container position-relative" style="z-index:5;">
        <div class="row align-items-center">
            <div class="col-lg-6" data-aos="fade-up">
                <div class="hero-badge bg-white bg-opacity-50 px-4 py-2 rounded-pill d-inline-block mb-4"><i class="fas fa-bolt text-warning me-2"></i> Next‑gen accessories · CCTV · E‑commerce</div>
                <h1 class="hero-title">Empower your<br>digital life</h1>
                <p class="fs-4 text-secondary mb-4">Mobile chargers · Headphones · Power banks · CCTV cameras · E‑commerce solutions</p>
                <div class="d-flex flex-wrap gap-3">
                    <a href="#business" class="btn btn-duha"><i class="fas fa-store me-2"></i>Explore divisions</a>
                    <a href="#contact" class="btn btn-outline-primary rounded-pill px-4 py-3 fw-bold"><i class="fas fa-headset me-2"></i>Talk to us</a>
                </div>
            </div>
            <div class="col-lg-6 d-none d-lg-block" data-aos="zoom-in-left">
                <div class="float-grid">
                    <div class="f-card card-1"><i class="fas fa-charging-station"></i><h5>Fast Charger</h5><small>GaN 65W</small></div>
                    <div class="f-card card-2"><i class="fas fa-headphones"></i><h5>Headphones</h5><small>ANC + Bass</small></div>
                    <div class="f-card card-3"><i class="fas fa-video"></i><h5>CCTV Camera</h5><small>4K / AI</small></div>
                    <div class="f-card card-4"><i class="fas fa-shopping-cart"></i><h5>E‑commerce</h5><small>B2B & D2C</small></div>
                </div>
            </div>
        </div>
    </div>
</section>

<!-- VISION & MISSION -->
<section id="vision" class="container py-5">
    <div class="text-center mb-5" data-aos="fade-up">
        <span class="badge bg-primary bg-opacity-10 text-primary px-4 py-2 rounded-pill mb-3"><i class="fas fa-flag-checkered me-1"></i> Our compass</span>
        <h2 class="section-title">Vision & Mission</h2>
        <p class="fs-5 text-secondary">Driven by innovation, quality, and global reach.</p>
    </div>
    <div class="row g-4">
        <div class="col-md-6" data-aos="fade-right">
            <div class="bg-white p-5 rounded-5 shadow-sm h-100">
                <i class="fas fa-binoculars fa-3x mb-4" style="color:#1e5eb0;"></i>
                <h3 class="fw-bold mb-3">🌍 Our Vision</h3>
                <p class="fs-5">To be the most trusted global technology partner in mobile accessories, security, and digital commerce — bridging Bangladesh with the world.</p>
            </div>
        </div>
        <div class="col-md-6" data-aos="fade-left">
            <div class="bg-white p-5 rounded-5 shadow-sm h-100">
                <i class="fas fa-bullseye fa-3x mb-4" style="color:#1e5eb0;"></i>
                <h3 class="fw-bold mb-3">🎯 Our Mission</h3>
                <p class="fs-5">Deliver premium chargers, headphones, power banks, CCTV systems, and e‑commerce services with unmatched quality, design, and customer care.</p>
            </div>
        </div>
    </div>
</section>

<!-- 🔥 IMAGE + CONTENT SECTIONS (Unsplash style visuals) -->
<section id="business" class="container py-5">
    <div class="text-center mb-5" data-aos="fade-up">
        <span class="badge bg-dark bg-opacity-75 text-white px-4 py-2 rounded-pill mb-3">⚡ Our core business</span>
        <h2 class="section-title">Image + Content showcase</h2>
        <p class="fs-5">Unsplash-inspired visuals paired with our business strengths</p>
    </div>

    <!-- 1. Mobile Charger (Image left, content right) -->
    <div class="row align-items-center g-5 mb-5" data-aos="fade-up">
        <div class="col-lg-6">
            <div class="img-card">
                <div class="img-placeholder" style="background-image: linear-gradient(0deg, #00000050, #00000010), url('https://images.pexels.com/photos/5926382/pexels-photo-5926382.jpeg?auto=compress&cs=tinysrgb&w=1260&h=750&dpr=2');">
                    <span class="badge bg-light text-dark p-3"><i class="fas fa-camera me-1"></i>Unsplash+ collection</span>
                </div>
                <div class="p-4">
                    <h4 class="fw-bold">⚡ GaN Fast Chargers</h4>
                    <p>65W / 100W multi‑port GaN technology. 3x faster, travel‑ready, and built with premium materials. Ideal for smartphones, laptops, and accessories.</p>
                    <a href="#" class="btn btn-outline-primary rounded-pill">View charger lineup <i class="fas fa-arrow-right"></i></a>
                </div>
            </div>
        </div>
        <div class="col-lg-6">
            <div class="p-4">
                <span class="badge bg-primary mb-3">New arrival</span>
                <h3 class="display-6 fw-bold">Power that keeps you moving</h3>
                <p class="fs-5">Duha GaN chargers are 40% smaller and deliver ultra-fast charging with intelligent protection. Perfect for business travelers and daily commuters. All our chargers come with 2-year warranty.</p>
                <ul class="list-unstyled">
                    <li class="mb-2"><i class="fas fa-check-circle text-success me-2"></i> Multi-port USB-C + USB-A</li>
                    <li class="mb-2"><i class="fas fa-check-circle text-success me-2"></i> Over-current & thermal protection</li>
                    <li class="mb-2"><i class="fas fa-check-circle text-success me-2"></i> Compact foldable plug</li>
                </ul>
            </div>
        </div>
    </div>

    <!-- 2. Headphones (Content left, image right) -->
    <div class="row align-items-center g-5 mb-5" data-aos="fade-up">
        <div class="col-lg-6 order-2 order-lg-1">
            <div class="p-4">
                <span class="badge bg-info text-dark mb-3">Audio division</span>
                <h3 class="display-6 fw-bold">Immersive sound, wireless freedom</h3>
                <p class="fs-5">ANC headphones and TWS earbuds with deep bass, crystal-clear calls, and 40h battery life. Perfect for remote work, music, and gaming.</p>
                <ul class="list-unstyled">
                    <li class="mb-2"><i class="fas fa-check-circle text-success me-2"></i> Active Noise Cancellation</li>
                    <li class="mb-2"><i class="fas fa-check-circle text-success me-2"></i> Bluetooth 5.3, multipoint connection</li>
                    <li class="mb-2"><i class="fas fa-check-circle text-success me-2"></i> Foldable & travel pouch included</li>
                </ul>
                <a href="#" class="btn btn-outline-primary rounded-pill mt-2">Explore audio <i class="fas fa-headphones"></i></a>
            </div>
        </div>
        <div class="col-lg-6 order-1 order-lg-2">
            <div class="img-card">
                <div class="img-placeholder" style="background-image: linear-gradient(0deg, #00000040, #00000010), url('https://images.pexels.com/photos/1649771/pexels-photo-1649771.jpeg?auto=compress&cs=tinysrgb&w=1260&h=750&dpr=2'); background-position: 40% 30%;">
                    <span class="badge bg-dark text-white p-3">Headphones collection</span>
                </div>
                <div class="p-4">
                    <h4 class="fw-bold">🎧 Studio & wireless headphones</h4>
                    <p>From over-ear ANC to sleek earbuds, our audio lineup brings comfort and clarity to every playlist and meeting.</p>
                </div>
            </div>
        </div>
    </div>

    <!-- 3. CCTV Camera (Image left, content right) -->
    <div class="row align-items-center g-5 mb-5" data-aos="fade-up">
        <div class="col-lg-6">
            <div class="img-card">
                <div class="img-placeholder" style="background-image: linear-gradient(0deg, #001e3b90, #00000010), url('https://images.pexels.com/photos/96612/pexels-photo-96612.jpeg?auto=compress&cs=tinysrgb&w=1260&h=750&dpr=2'); background-position: 20% 30%;">
                    <span class="badge bg-light text-dark p-3"><i class="fas fa-shield-alt"></i> Security solution</span>
                </div>
                <div class="p-4">
                    <h4 class="fw-bold">📹 CCTV & Surveillance</h4>
                    <p>4MP / 4K IP cameras with AI motion detection, night vision, and remote access. Suitable for home, office, and industrial sites.</p>
                    <a href="#" class="btn btn-outline-primary rounded-pill">Request security quote</a>
                </div>
            </div>
        </div>
        <div class="col-lg-6">
            <div class="p-4">
                <span class="badge bg-success mb-3">CCTV business unit</span>
                <h3 class="display-6 fw-bold">Smart surveillance, total peace</h3>
                <p class="fs-5">Duha provides end‑to‑end CCTV solutions: cameras, NVR, and installation support. We help businesses secure their assets with modern AI analytics.</p>
                <ul class="list-unstyled">
                    <li class="mb-2"><i class="fas fa-check-circle text-success me-2"></i> 4K resolution with color night vision</li>
                    <li class="mb-2"><i class="fas fa-check-circle text-success me-2"></i> Human/vehicle detection & alerts</li>
                    <li class="mb-2"><i class="fas fa-check-circle text-success me-2"></i> Cloud & local storage options</li>
                </ul>
            </div>
        </div>
    </div>

    <!-- 4. E‑commerce (Content left, image right) -->
    <div class="row align-items-center g-5 mb-5" data-aos="fade-up">
        <div class="col-lg-6 order-2 order-lg-1">
            <div class="p-4">
                <span class="badge bg-warning text-dark mb-3">E‑commerce solutions</span>
                <h3 class="display-6 fw-bold">Sell smarter, scale faster</h3>
                <p class="fs-5">From dropshipping support to full online store management, Duha helps businesses grow on Amazon, Shopify, and local marketplaces.</p>
                <ul class="list-unstyled">
                    <li class="mb-2"><i class="fas fa-check-circle text-success me-2"></i> Product sourcing & private labeling</li>
                    <li class="mb-2"><i class="fas fa-check-circle text-success me-2"></i> Multi-channel inventory sync</li>
                    <li class="mb-2"><i class="fas fa-check-circle text-success me-2"></i> Professional product photography</li>
                </ul>
                <a href="#" class="btn btn-outline-primary rounded-pill">Partner with us</a>
            </div>
        </div>
        <div class="col-lg-6 order-1 order-lg-2">
            <div class="img-card">
                <div class="img-placeholder" style="background-image: linear-gradient(0deg, #0a264770, #00000020), url('https://images.pexels.com/photos/230544/pexels-photo-230544.jpeg?auto=compress&cs=tinysrgb&w=1260&h=750&dpr=2'); background-position: center;">
                    <span class="badge bg-white text-dark p-3"><i class="fas fa-shopping-cart"></i> E‑commerce</span>
                </div>
                <div class="p-4">
                    <h4 class="fw-bold">🛒 E‑commerce & fulfillment</h4>
                    <p>We provide a complete ecosystem for online sellers — from sourcing trending accessories to warehousing and shipping.</p>
                </div>
            </div>
        </div>
    </div>
</section>

<!-- COMPANY STORY + TIMELINE -->
<section id="story" class="container py-5">
    <div class="bg-white p-5 rounded-5 shadow-sm" data-aos="fade-up">
        <div class="row align-items-center">
            <div class="col-lg-5">
                <span class="badge bg-dark text-white mb-3 px-4 py-2"><i class="fas fa-feather-alt"></i> Our journey</span>
                <h3 class="display-5 fw-bold mb-4" style="color: #0f2c4e;">From a small shop to global technology</h3>
                <p class="fs-5">Duha Global Technology started in 2018 with a vision to bring premium mobile accessories to Bangladesh. Today we serve clients in 12+ countries, covering chargers, audio, CCTV, and e‑commerce fulfillment.</p>
                <hr>
                <p><i class="fas fa-quote-right me-2 text-muted"></i> “Innovation and integrity drive every product.” — CEO</p>
            </div>
            <div class="col-lg-7">
                <div class="row g-3">
                    <div class="col-6"><div class="bg-light p-4 rounded-4"><i class="fas fa-store fa-2x mb-2 text-primary"></i><h5>Retail roots</h5><small>Started as a mobile shop</small></div></div>
                    <div class="col-6"><div class="bg-light p-4 rounded-4"><i class="fas fa-video fa-2x mb-2 text-primary"></i><h5>CCTV division</h5><small>Launched in 2021</small></div></div>
                    <div class="col-6"><div class="bg-light p-4 rounded-4"><i class="fas fa-globe fa-2x mb-2 text-primary"></i><h5>E‑commerce arm</h5><small>2022 – present</small></div></div>
                    <div class="col-6"><div class="bg-light p-4 rounded-4"><i class="fas fa-rocket fa-2x mb-2 text-primary"></i><h5>Global expansion</h5><small>2026 and beyond</small></div></div>
                </div>
            </div>
        </div>
    </div>
</section>