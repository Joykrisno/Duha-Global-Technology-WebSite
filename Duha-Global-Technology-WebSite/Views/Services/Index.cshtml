@{
    ViewData["Title"] = "Services";
    Layout = "~/Views/Shared/_Layout.cshtml";
}

 
    <style>
        /* ===== SERVICES PAGE ===== */

        /* HERO */
        .services-hero {
            padding: 5rem 1.5rem 4rem;
            background: radial-gradient(ellipse at 20% 40%, #d6eaff, #f6faff 80%);
            position: relative;
            overflow: hidden;
        }

            .services-hero::before {
                content: '';
                position: absolute;
                width: 600px;
                height: 600px;
                background: radial-gradient(circle, #b8d8ff18, transparent 70%);
                top: -200px;
                right: -150px;
                border-radius: 50%;
            }

            .services-hero::after {
                content: '';
                position: absolute;
                width: 280px;
                height: 280px;
                background: radial-gradient(circle, #d0e9ff15, transparent 70%);
                bottom: -80px;
                left: 80px;
                border-radius: 50%;
            }

        .services-page-title {
            font-size: 3.6rem;
            font-weight: 800;
            line-height: 1.12;
            background: linear-gradient(135deg, #021c33, #1f509e);
            -webkit-background-clip: text;
            background-clip: text;
            color: transparent;
        }

        /* SECTION LABEL */
        .section-label {
            display: inline-block;
            background: #eaf2ff;
            color: #1a5096;
            font-size: 0.78rem;
            font-weight: 700;
            letter-spacing: 0.08em;
            text-transform: uppercase;
            padding: 6px 18px;
            border-radius: 40px;
            margin-bottom: 14px;
        }

        /* DIVIDER */
        .section-divider {
            height: 2px;
            background: linear-gradient(90deg, transparent, #d0e4f7, transparent);
            border: none;
            margin: 0;
        }

        /* ── HERO SERVICE CARDS (big 4) ── */
        .hero-service-card {
            background: white;
            border-radius: 32px;
            padding: 2.2rem 1.8rem;
            border: 1.5px solid #e0eeff;
            height: 100%;
            position: relative;
            overflow: hidden;
            transition: all 0.35s;
            cursor: default;
        }

            .hero-service-card::after {
                content: '';
                position: absolute;
                bottom: 0;
                left: 0;
                right: 0;
                height: 4px;
                border-radius: 0 0 32px 32px;
                opacity: 0;
                transition: opacity 0.3s;
            }

        .hsc-blue::after {
            background: linear-gradient(90deg,#0b2a4e,#2266bb);
        }

        .hsc-green::after {
            background: linear-gradient(90deg,#198754,#2bc176);
        }

        .hsc-orange::after {
            background: linear-gradient(90deg,#e65c00,#f9a825);
        }

        .hsc-purple::after {
            background: linear-gradient(90deg,#6a11cb,#2575fc);
        }

        .hero-service-card:hover {
            transform: translateY(-10px);
            box-shadow: 0 32px 52px -16px #0a3a6e30;
            border-color: #b3d0f0;
        }

            .hero-service-card:hover::after {
                opacity: 1;
            }

        .hsc-icon {
            width: 72px;
            height: 72px;
            border-radius: 22px;
            display: flex;
            align-items: center;
            justify-content: center;
            font-size: 2rem;
            margin-bottom: 1.4rem;
            transition: all 0.3s;
        }

        .hsc-blue .hsc-icon {
            background: #eaf2ff;
            color: #1a5096;
        }

        .hsc-green .hsc-icon {
            background: #eafaf1;
            color: #198754;
        }

        .hsc-orange .hsc-icon {
            background: #fff4e5;
            color: #e65c00;
        }

        .hsc-purple .hsc-icon {
            background: #f3eeff;
            color: #6a11cb;
        }

        .hero-service-card:hover .hsc-icon {
            transform: scale(1.1) rotate(-4deg);
        }

        .hero-service-card h4 {
            font-weight: 800;
            color: #0b1c2e;
            margin-bottom: 10px;
            font-size: 1.2rem;
        }

        .hero-service-card p {
            color: #6b7d93;
            font-size: 0.93rem;
            line-height: 1.7;
            margin: 0;
        }

        .hsc-tag {
            display: inline-block;
            font-size: 0.7rem;
            font-weight: 700;
            letter-spacing: 0.06em;
            padding: 4px 12px;
            border-radius: 40px;
            margin-bottom: 10px;
        }

        .hsc-blue .hsc-tag {
            background: #eaf2ff;
            color: #1a5096;
        }

        .hsc-green .hsc-tag {
            background: #eafaf1;
            color: #198754;
        }

        .hsc-orange .hsc-tag {
            background: #fff4e5;
            color: #e65c00;
        }

        .hsc-purple .hsc-tag {
            background: #f3eeff;
            color: #6a11cb;
        }

        /* ── E-COMMERCE SECTION ── */
        .ecom-section {
            background: linear-gradient(135deg, #0b2a4e 0%, #163d6e 100%);
            border-radius: 44px;
            padding: 4rem 3.5rem;
            position: relative;
            overflow: hidden;
            color: white;
        }

            .ecom-section::before {
                content: '';
                position: absolute;
                width: 500px;
                height: 500px;
                background: rgba(255,255,255,0.03);
                border-radius: 50%;
                top: -180px;
                right: -120px;
            }

            .ecom-section::after {
                content: '';
                position: absolute;
                width: 280px;
                height: 280px;
                background: rgba(255,255,255,0.025);
                border-radius: 50%;
                bottom: -90px;
                left: 60px;
            }

        .ecom-feature {
            display: flex;
            align-items: flex-start;
            gap: 16px;
            margin-bottom: 1.8rem;
        }

            .ecom-feature:last-child {
                margin-bottom: 0;
            }

        .ecom-feat-icon {
            min-width: 48px;
            height: 48px;
            border-radius: 14px;
            background: rgba(255,255,255,0.1);
            border: 1px solid rgba(255,255,255,0.15);
            display: flex;
            align-items: center;
            justify-content: center;
            font-size: 1.3rem;
            color: #7ab8f5;
            transition: all 0.25s;
        }

        .ecom-feature:hover .ecom-feat-icon {
            background: #2266bb;
            border-color: #2266bb;
            transform: scale(1.08);
        }

        .ecom-feature h6 {
            font-weight: 700;
            color: white;
            margin-bottom: 4px;
        }

        .ecom-feature p {
            font-size: 0.87rem;
            color: #a0bdd8;
            margin: 0;
            line-height: 1.6;
        }

        .platform-chip {
            display: inline-flex;
            align-items: center;
            gap: 8px;
            background: rgba(255,255,255,0.08);
            border: 1px solid rgba(255,255,255,0.15);
            color: white;
            border-radius: 50px;
            padding: 8px 18px;
            font-size: 0.85rem;
            font-weight: 600;
            margin: 5px;
            transition: all 0.2s;
        }

            .platform-chip:hover {
                background: rgba(255,255,255,0.18);
                transform: translateY(-3px);
            }

        /* ── DEALERSHIP SECTION ── */
        .deal-step {
            text-align: center;
            position: relative;
        }

        .deal-step-num {
            width: 56px;
            height: 56px;
            border-radius: 50%;
            background: #0b2a4e;
            color: #7ab8f5;
            font-size: 1.3rem;
            font-weight: 800;
            display: flex;
            align-items: center;
            justify-content: center;
            margin: 0 auto 1rem;
            box-shadow: 0 10px 24px -8px #0b2a4e60;
            transition: all 0.3s;
        }

        .deal-step:hover .deal-step-num {
            background: #2266bb;
            transform: scale(1.1);
        }

        .deal-step h6 {
            font-weight: 700;
            color: #0b1c2e;
            margin-bottom: 6px;
        }

        .deal-step p {
            font-size: 0.85rem;
            color: #6b7d93;
            line-height: 1.6;
            margin: 0;
        }

        .deal-connector {
            position: absolute;
            top: 28px;
            right: -28%;
            width: 56%;
            height: 2px;
            background: linear-gradient(90deg, #2266bb, #d0e4f7);
            z-index: 0;
        }

        .deal-step {
            z-index: 1;
        }

        .deal-perk {
            background: white;
            border-radius: 22px;
            padding: 1.6rem 1.4rem;
            border: 1.5px solid #e0eeff;
            display: flex;
            align-items: center;
            gap: 16px;
            transition: all 0.3s;
        }

            .deal-perk:hover {
                transform: translateY(-6px);
                box-shadow: 0 22px 36px -12px #0a3a6e22;
                border-color: #b3d0f0;
            }

        .deal-perk-icon {
            min-width: 52px;
            height: 52px;
            border-radius: 16px;
            background: #eaf2ff;
            display: flex;
            align-items: center;
            justify-content: center;
            font-size: 1.5rem;
            color: #1a5096;
            transition: all 0.3s;
        }

        .deal-perk:hover .deal-perk-icon {
            background: #0b2a4e;
            color: #7ab8f5;
        }

        .deal-perk h6 {
            font-weight: 700;
            color: #0b1c2e;
            margin-bottom: 3px;
            font-size: 0.95rem;
        }

        .deal-perk p {
            font-size: 0.82rem;
            color: #6b7d93;
            margin: 0;
            line-height: 1.5;
        }

        /* ── DELIVERY / TRANSPORT SECTION ── */
        .delivery-hero-box {
            background: linear-gradient(135deg, #198754, #0d6b41);
            border-radius: 44px;
            padding: 4rem 3.5rem;
            color: white;
            position: relative;
            overflow: hidden;
        }

            .delivery-hero-box::before {
                content: '';
                position: absolute;
                width: 450px;
                height: 450px;
                background: rgba(255,255,255,0.04);
                border-radius: 50%;
                top: -160px;
                right: -100px;
            }

            .delivery-hero-box::after {
                content: '';
                position: absolute;
                width: 220px;
                height: 220px;
                background: rgba(255,255,255,0.03);
                border-radius: 50%;
                bottom: -70px;
                left: 50px;
            }

        .delivery-badge-big {
            display: inline-flex;
            align-items: center;
            gap: 10px;
            background: rgba(255,255,255,0.12);
            border: 1px solid rgba(255,255,255,0.2);
            border-radius: 50px;
            padding: 10px 24px;
            font-weight: 700;
            font-size: 1rem;
            color: white;
            margin-bottom: 1.5rem;
        }

        .delivery-stat {
            background: rgba(255,255,255,0.1);
            border: 1px solid rgba(255,255,255,0.15);
            border-radius: 20px;
            padding: 1.2rem 1rem;
            text-align: center;
            transition: all 0.2s;
        }

            .delivery-stat:hover {
                background: rgba(255,255,255,0.18);
                transform: translateY(-4px);
            }

            .delivery-stat .d-num {
                font-size: 2rem;
                font-weight: 800;
                color: white;
                line-height: 1;
            }

            .delivery-stat .d-lbl {
                font-size: 0.78rem;
                color: rgba(255,255,255,0.7);
                margin-top: 4px;
            }

        .delivery-step-card {
            background: white;
            border-radius: 24px;
            padding: 1.8rem 1.5rem;
            border: 1.5px solid #e0eeff;
            height: 100%;
            text-align: center;
            transition: all 0.3s;
        }

            .delivery-step-card:hover {
                transform: translateY(-8px);
                box-shadow: 0 24px 40px -12px #0a3a6e25;
                border-color: #b3d0f0;
            }

        .dsc-icon {
            width: 64px;
            height: 64px;
            border-radius: 20px;
            background: #eaf2ff;
            display: flex;
            align-items: center;
            justify-content: center;
            font-size: 1.8rem;
            color: #1a5096;
            margin: 0 auto 1rem;
            transition: all 0.3s;
        }

        .delivery-step-card:hover .dsc-icon {
            background: #0b2a4e;
            color: #7ab8f5;
        }

        .delivery-step-card h6 {
            font-weight: 700;
            color: #0b1c2e;
            margin-bottom: 6px;
        }

        .delivery-step-card p {
            font-size: 0.85rem;
            color: #6b7d93;
            margin: 0;
            line-height: 1.6;
        }

        .free-tag {
            background: #198754;
            color: white;
            font-size: 0.7rem;
            font-weight: 800;
            letter-spacing: 0.06em;
            padding: 3px 10px;
            border-radius: 40px;
            vertical-align: middle;
            margin-left: 6px;
        }

        /* ── CCTV INSTALLATION ── */
        .install-card {
            background: white;
            border-radius: 28px;
            padding: 2rem 1.8rem;
            border: 1.5px solid #e0eeff;
            height: 100%;
            transition: all 0.3s;
            position: relative;
            overflow: hidden;
        }

            .install-card::before {
                content: '';
                position: absolute;
                top: 0;
                left: 0;
                right: 0;
                height: 3px;
                background: linear-gradient(90deg,#0b2a4e,#2266bb);
                opacity: 0;
                transition: opacity 0.3s;
            }

            .install-card:hover {
                transform: translateY(-8px);
                box-shadow: 0 28px 44px -14px #0a3a6e25;
                border-color: #b3d0f0;
            }

                .install-card:hover::before {
                    opacity: 1;
                }

            .install-card .ic-icon {
                font-size: 2.4rem;
                color: #1a5096;
                margin-bottom: 1rem;
                display: block;
            }

            .install-card h5 {
                font-weight: 700;
                color: #0b1c2e;
                margin-bottom: 8px;
            }

            .install-card p {
                font-size: 0.88rem;
                color: #6b7d93;
                line-height: 1.7;
                margin-bottom: 12px;
            }

            .install-card ul {
                list-style: none;
                padding: 0;
                margin: 0;
            }

                .install-card ul li {
                    font-size: 0.85rem;
                    color: #4a6380;
                    margin-bottom: 6px;
                }

                    .install-card ul li i {
                        color: #198754;
                        margin-right: 7px;
                    }

        /* ── PRICING PLANS ── */
        .plan-card {
            background: white;
            border-radius: 32px;
            padding: 2.5rem 2rem;
            border: 1.5px solid #e0eeff;
            height: 100%;
            transition: all 0.3s;
            position: relative;
            text-align: center;
        }

            .plan-card.featured {
                border: 2px solid #2266bb;
                box-shadow: 0 20px 40px -12px #2266bb30;
            }

            .plan-card:hover {
                transform: translateY(-10px);
                box-shadow: 0 32px 52px -16px #0a3a6e30;
            }

        .plan-badge {
            position: absolute;
            top: -14px;
            left: 50%;
            transform: translateX(-50%);
            background: #0b2a4e;
            color: white;
            font-size: 0.72rem;
            font-weight: 800;
            letter-spacing: 0.06em;
            padding: 5px 18px;
            border-radius: 40px;
            white-space: nowrap;
        }

        .plan-icon {
            width: 70px;
            height: 70px;
            border-radius: 22px;
            display: flex;
            align-items: center;
            justify-content: center;
            font-size: 1.9rem;
            margin: 0 auto 1.2rem;
        }

        .plan-card h4 {
            font-weight: 800;
            color: #0b1c2e;
            margin-bottom: 6px;
        }

        .plan-card .plan-price {
            font-size: 2.5rem;
            font-weight: 800;
            color: #0b2a4e;
            line-height: 1;
            margin: 1rem 0 0.3rem;
        }

        .plan-card .plan-period {
            font-size: 0.85rem;
            color: #8ea3ba;
            margin-bottom: 1.4rem;
        }

        .plan-card .plan-desc {
            font-size: 0.88rem;
            color: #6b7d93;
            margin-bottom: 1.4rem;
            line-height: 1.65;
        }

        .plan-card ul {
            list-style: none;
            padding: 0;
            margin: 0 0 1.8rem;
            text-align: left;
        }

            .plan-card ul li {
                font-size: 0.87rem;
                color: #4a6380;
                margin-bottom: 10px;
                display: flex;
                align-items: center;
                gap: 10px;
            }

                .plan-card ul li i.yes {
                    color: #198754;
                }

                .plan-card ul li i.no {
                    color: #ccc;
                }

        /* ── PROCESS TIMELINE (horizontal) ── */
        .process-row {
            display: flex;
            gap: 0;
            align-items: stretch;
            flex-wrap: nowrap;
            overflow-x: auto;
            padding-bottom: 8px;
        }

        .process-step {
            flex: 1;
            min-width: 140px;
            background: white;
            border: 1.5px solid #e0eeff;
            border-radius: 0;
            padding: 1.8rem 1.2rem;
            text-align: center;
            position: relative;
            transition: all 0.3s;
        }

            .process-step:first-child {
                border-radius: 24px 0 0 24px;
            }

            .process-step:last-child {
                border-radius: 0 24px 24px 0;
            }

            .process-step:hover {
                background: #f0f7ff;
                border-color: #b3d0f0;
                z-index: 1;
            }

        .ps-num {
            width: 40px;
            height: 40px;
            border-radius: 50%;
            background: #0b2a4e;
            color: #7ab8f5;
            font-weight: 800;
            font-size: 1rem;
            display: flex;
            align-items: center;
            justify-content: center;
            margin: 0 auto 10px;
        }

        .process-step h6 {
            font-weight: 700;
            color: #0b1c2e;
            font-size: 0.88rem;
            margin-bottom: 4px;
        }

        .process-step p {
            font-size: 0.78rem;
            color: #6b7d93;
            margin: 0;
            line-height: 1.5;
        }

        .ps-arrow {
            position: absolute;
            right: -14px;
            top: 50%;
            transform: translateY(-50%);
            width: 28px;
            height: 28px;
            background: #2266bb;
            border-radius: 50%;
            display: flex;
            align-items: center;
            justify-content: center;
            color: white;
            font-size: 0.7rem;
            z-index: 2;
            box-shadow: 0 4px 10px #2266bb40;
        }

        .process-step:last-child .ps-arrow {
            display: none;
        }

        /* ── CTA BANNER ── */
        .services-cta {
            background: linear-gradient(135deg, #0b2a4e, #1a5096);
            border-radius: 40px;
            padding: 4rem 3rem;
            text-align: center;
            position: relative;
            overflow: hidden;
        }

            .services-cta::before {
                content: '';
                position: absolute;
                width: 400px;
                height: 400px;
                background: rgba(255,255,255,0.04);
                border-radius: 50%;
                top: -150px;
                right: -80px;
            }

        /* RESPONSIVE */
        @@media (max-width: 992px) {
            .ecom-section, .delivery-hero-box

        {
            padding: 2.5rem 1.8rem;
            border-radius: 28px;
        }

        .services-page-title {
            font-size: 2.6rem;
        }

        .process-row {
            flex-wrap: wrap;
        }

        .process-step {
            min-width: 46%;
            border-radius: 16px !important;
            margin: 4px;
            border: 1.5px solid #e0eeff;
        }

        .ps-arrow {
            display: none !important;
        }

        }
        @@media (max-width: 576px) {
            .services-page-title

        {
            font-size: 2rem;
        }

        .ecom-section, .delivery-hero-box {
            padding: 2rem 1.2rem;
            border-radius: 22px;
        }

        .services-cta {
            padding: 2.5rem 1.2rem;
            border-radius: 26px;
        }

        .process-step {
            min-width: 90%;
        }

        }
    </style>
 

<!-- ══════════════════════════════════════════════════
     HERO
══════════════════════════════════════════════════ -->
<section class="services-hero">
    <div class="container position-relative" style="z-index:5;">
        <div class="row align-items-center g-5">
            <div class="col-lg-6" data-aos="fade-up">
                <span class="section-label"><i class="fas fa-cogs me-1"></i>Our Services</span>
                <h1 class="services-page-title">Everything your<br>business needs</h1>
                <p class="fs-5 text-secondary mt-3 mb-4" style="line-height:1.75;">
                    From premium product supply to free dealership delivery, e-commerce management to CCTV installation — Duha Global is your end-to-end technology partner.
                </p>
                <div class="d-flex flex-wrap gap-3">
                    <a href="#dealership-section" class="btn btn-duha"><i class="fas fa-handshake me-2"></i>Become a Dealer</a>
                    <a href="#contact" class="btn btn-outline-primary rounded-pill px-4 py-3 fw-bold"><i class="fas fa-phone-alt me-2"></i>Talk to Us</a>
                </div>
            </div>
            <div class="col-lg-6 d-none d-lg-block" data-aos="zoom-in-left">
                <div class="float-grid">
                    <div class="f-card card-1"><i class="fas fa-shopping-cart"></i><h5>E-commerce</h5><small>Full service</small></div>
                    <div class="f-card card-2"><i class="fas fa-truck"></i><h5>Free Delivery</h5><small>Dealer ship</small></div>
                    <div class="f-card card-3"><i class="fas fa-video"></i><h5>CCTV Install</h5><small>Turnkey</small></div>
                    <div class="f-card card-4"><i class="fas fa-handshake"></i><h5>Dealership</h5><small>300+ partners</small></div>
                </div>
            </div>
        </div>
    </div>
</section>

<!-- ══════════════════════════════════════════════════
     4 CORE SERVICE OVERVIEW CARDS
══════════════════════════════════════════════════ -->
<section class="container py-5">
    <div class="text-center mb-5" data-aos="fade-up">
        <span class="section-label"><i class="fas fa-th-large me-1"></i>What We Offer</span>
        <h2 class="section-title">Our core services</h2>
        <p class="fs-5 text-secondary">Four pillars that power Duha Global Technology.</p>
    </div>
    <div class="row g-4">

        <div class="col-sm-6 col-lg-3" data-aos="fade-up">
            <div class="hero-service-card hsc-blue">
                <div class="hsc-tag">Accessories</div>
                <div class="hsc-icon"><i class="fas fa-box-open"></i></div>
                <h4>Product Supply & Distribution</h4>
