<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Duha Global Technology • Chargers · CCTV · E‑commerce</title>
    <!-- Bootstrap + Font Awesome + Google Fonts + AOS -->
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/bootstrap/5.3.0/css/bootstrap.min.css" />
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.0.0-beta3/css/all.min.css" />
    <link href="https://fonts.googleapis.com/css2?family=Inter:opsz,wght@14..32,400;14..32,500;14..32,600;14..32,700;14..32,800&display=swap" rel="stylesheet" />
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/aos/2.3.4/aos.css" />
    <link rel="stylesheet" href="~/css/HomePage.css" />
</head>
<body>
 
    <!-- 🌟 NAVIGATION WITH DUHA LOGO -->
    <header>
        <nav class="navbar navbar-expand-lg navbar-custom">
            <div class="container-fluid">

                <!-- Logo + Brand -->
                <a class="navbar-brand-custom" href="#">
                    <img src="~/img/duhalogo.jpg" alt="Duha Logo" />
                    <span class="brand-text">Duha Global</span>
                </a>

                <!-- Toggle button (mobile) -->
                <button class="navbar-toggler" type="button" data-bs-toggle="collapse" data-bs-target="#navbarDuha">
                    <span class="navbar-toggler-icon"></span>
                </button>

                <!-- Menu -->
                <div class="collapse navbar-collapse" id="navbarDuha">
                    <ul class="navbar-nav ms-auto mb-2 mb-lg-0 align-items-center">

                        <li class="nav-item">
                            <a class="nav-link" asp-controller="Home" asp-action="Index">
                                </a>
                            </li>
                        <li class="nav-item">
                            <a class="nav-link" asp-controller="About" asp-action="Index">
                            <i class="fas fa-building"></i>About</a>
                            </li>
                        <li class="nav-item">
                            <a class="nav-link" asp-controller="Product" asp-action="Index">
                                <i class="fas fa-box"></i>Products
                            </a>
                        </li>
                        <li class="nav-item">
                            <a class="nav-link" asp-controller="Services" asp-action="Index">
                                <i class="fas fa-cogs"></i>Services</a>
                            </li>
                        <li class="nav-item">
                            <a class="nav-link" asp-controller="Dealership" asp-action="Index">
                                <i class="fas fa-handshake"></i>Dealership
                                </a>
                            </li>
                        <li class="nav-item"><a class="nav-link" href="#contact"><i class="fas fa-phone-alt"></i>Contact</a></li>

                    </ul>
                </div>

            </div>
        </nav>
    </header>

    @RenderBody()

    <!-- FOOTER -->
    <footer class="footer-duha" id="contact">
        <div class="container">
            <div class="row gy-4">
                <div class="col-md-5">
                    <div class="d-flex align-items-center mb-3">
                        <img src="d:\duha_group_project\duha-global-technology-website\duha-global-technology-website\wwwroot\duhalogo.jpg" style="height: 52px; border-radius: 16px; margin-right: 15px; border: 2px solid #3469a8;" onerror="this.style.display='none'">
                        <span style="font-size: 2rem; font-weight: 800; color: white;">Duha Global</span>
                    </div>
                    <p>Premium mobile accessories, CCTV, and e‑commerce solutions.</p>
                    <p><i class="fas fa-map-marker-alt me-2"></i> Dhaka, Bangladesh | Global shipping</p>
                </div>
                <div class="col-md-3">
                    <h5 class="text-white">Quick links</h5>
                    <ul class="list-unstyled">
                        <li><a href="#vision" class="text-white-50 text-decoration-none">Vision & Mission</a></li>
                        <li><a href="#business" class="text-white-50 text-decoration-none">Business units</a></li>
                        <li><a href="#story" class="text-white-50 text-decoration-none">Company story</a></li>
                        <li><a href="#" class="text-white-50 text-decoration-none">Privacy Policy</a></li>
                    </ul>
                </div>
                <div class="col-md-4">
                    <h5 class="text-white">Connect</h5>
                    <p><i class="fas fa-envelope me-2"></i> hello@duhaglobal.com</p>
                    <div class="fs-3">
                        <a href="#" class="text-white-50 me-3"><i class="fab fa-facebook"></i></a>
                        <a href="#" class="text-white-50 me-3"><i class="fab fa-linkedin"></i></a>
                        <a href="#" class="text-white-50"><i class="fab fa-instagram"></i></a>
                    </div>
                </div>
            </div>
            <hr class="opacity-25">
            <div class="d-flex justify-content-between">
                <span>© 2026 Duha Global Technology. All rights reserved.</span>
                <span>Made with <i class="fas fa-heart text-danger"></i> for innovation</span>
            </div>
        </div>
    </footer>

    <!-- Scripts -->
    <script src="https://cdnjs.cloudflare.com/ajax/libs/bootstrap/5.3.0/js/bootstrap.bundle.min.js"></script>
    <script src="https://cdnjs.cloudflare.com/ajax/libs/aos/2.3.4/aos.js"></script>
    <script>
        AOS.init({ once: false, duration: 900, easing: 'ease-out' });
    </script>
    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>