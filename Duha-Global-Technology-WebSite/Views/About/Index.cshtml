@{
    ViewData["Title"] = "About";
    Layout = "~/Views/Shared/_Layout.cshtml";
}

 
    <style>
        /* ===== ABOUT PAGE STYLES ===== */

        /* HERO */
        .about-hero {
            padding: 5rem 1.5rem 4rem;
            background: radial-gradient(ellipse at 15% 50%, #daeaff, #f6faff 75%);
            position: relative;
            overflow: hidden;
        }

            .about-hero::before {
                content: '';
                position: absolute;
                width: 550px;
                height: 550px;
                background: radial-gradient(circle, #b8d8ff22, transparent 70%);
                top: -180px;
                right: -120px;
                border-radius: 50%;
            }

            .about-hero::after {
                content: '';
                position: absolute;
                width: 300px;
                height: 300px;
                background: radial-gradient(circle, #d0e9ff18, transparent 70%);
                bottom: -80px;
                left: 60px;
                border-radius: 50%;
            }

        .about-page-title {
            font-size: 3.6rem;
            font-weight: 800;
            line-height: 1.12;
            background: linear-gradient(135deg, #021c33, #1f509e);
            -webkit-background-clip: text;
            background-clip: text;
            color: transparent;
        }

        .about-hero-img {
            border-radius: 36px;
            overflow: hidden;
            box-shadow: 0 40px 60px -20px #0a3a6e35;
            position: relative;
        }

            .about-hero-img img {
                width: 100%;
                height: 380px;
                object-fit: cover;
                display: block;
                transition: transform 0.5s ease;
            }

            .about-hero-img:hover img {
                transform: scale(1.04);
            }

            .about-hero-img .img-overlay-badge {
                position: absolute;
                bottom: 20px;
                left: 20px;
                background: rgba(11,26,46,0.82);
                backdrop-filter: blur(12px);
                color: white;
                border-radius: 20px;
                padding: 12px 22px;
                font-weight: 700;
                font-size: 0.95rem;
                border: 1px solid rgba(255,255,255,0.15);
            }

        /* FLOATING STAT CARDS */
        .stat-float-grid {
            display: grid;
            grid-template-columns: 1fr 1fr;
            gap: 16px;
        }

        .stat-float-card {
            background: white;
            border-radius: 24px;
            padding: 1.5rem 1.2rem;
            text-align: center;
            box-shadow: 0 20px 35px -10px #0a3a6e20;
            border: 1.5px solid #e0eeff;
            transition: all 0.3s;
        }

            .stat-float-card:hover {
                transform: translateY(-6px);
                box-shadow: 0 30px 45px -14px #0a3a6e35;
                border-color: #b3d0f0;
            }

            .stat-float-card .stat-num {
                font-size: 2.4rem;
                font-weight: 800;
                background: linear-gradient(135deg, #0b2a4e, #2266bb);
                -webkit-background-clip: text;
                background-clip: text;
                color: transparent;
                line-height: 1;
                margin-bottom: 4px;
            }

            .stat-float-card .stat-icon {
                font-size: 1.8rem;
                color: #2266bb;
                margin-bottom: 10px;
            }

            .stat-float-card .stat-lbl {
                font-size: 0.82rem;
                font-weight: 600;
                color: #6b84a0;
                letter-spacing: 0.04em;
                text-transform: uppercase;
            }

        /* DIVIDER WAVE */
        .section-divider {
            height: 2px;
            background: linear-gradient(90deg, transparent, #d0e4f7, transparent);
            margin: 0;
            border: none;
        }

        /* ABOUT SECTION TITLES */
        .about-section-label {
            display: inline-block;
            background: #eaf2ff;
            color: #1a5096;
            font-size: 0.78rem;
            font-weight: 700;
            letter-spacing: 0.08em;
            text-transform: uppercase;
            padding: 6px 18px;
            border-radius: 40px;
            margin-bottom: 14px;
        }

        /* VALUES CARDS */
        .value-card {
            background: white;
            border-radius: 28px;
            padding: 2rem 1.6rem;
            border: 1.5px solid #e4eef8;
            height: 100%;
            transition: all 0.3s;
            position: relative;
            overflow: hidden;
        }

            .value-card::before {
                content: '';
                position: absolute;
                top: 0;
                left: 0;
                right: 0;
                height: 4px;
                background: linear-gradient(90deg, #0b2a4e, #2266bb);
                opacity: 0;
                transition: opacity 0.3s;
            }

            .value-card:hover {
                transform: translateY(-8px);
                box-shadow: 0 28px 44px -14px #0a3a6e28;
                border-color: #b3d0f0;
            }

                .value-card:hover::before {
                    opacity: 1;
                }

        .value-icon {
            width: 60px;
            height: 60px;
            border-radius: 18px;
            background: #eaf2ff;
            display: flex;
            align-items: center;
            justify-content: center;
            font-size: 1.7rem;
            color: #1a5096;
            margin-bottom: 1.2rem;
            transition: all 0.3s;
        }

        .value-card:hover .value-icon {
            background: #0b2a4e;
            color: #7ab8f5;
        }

        .value-card h5 {
            font-weight: 700;
            color: #0b1c2e;
            margin-bottom: 8px;
        }

        .value-card p {
            font-size: 0.9rem;
            color: #6b7d93;
            margin: 0;
            line-height: 1.65;
        }

        /* TIMELINE */
        .timeline {
            position: relative;
            padding-left: 2.5rem;
        }

            .timeline::before {
                content: '';
                position: absolute;
                left: 10px;
                top: 6px;
                bottom: 6px;
                width: 2px;
                background: linear-gradient(180deg, #2266bb, #d0e4f7);
                border-radius: 2px;
            }

        .timeline-item {
            position: relative;
            margin-bottom: 2.4rem;
        }

            .timeline-item:last-child {
                margin-bottom: 0;
            }

        .timeline-dot {
            position: absolute;
            left: -2.1rem;
            top: 4px;
            width: 18px;
            height: 18px;
            border-radius: 50%;
            background: #2266bb;
            border: 3px solid #eaf2ff;
            box-shadow: 0 0 0 3px #2266bb30;
            transition: all 0.3s;
        }

        .timeline-item:hover .timeline-dot {
            background: #0b2a4e;
            box-shadow: 0 0 0 5px #0b2a4e20;
            transform: scale(1.2);
        }

        .timeline-year {
            font-size: 0.72rem;
            font-weight: 800;
            color: #2266bb;
            letter-spacing: 0.07em;
            text-transform: uppercase;
            margin-bottom: 4px;
        }

        .timeline-title {
            font-weight: 700;
            color: #0b1c2e;
            font-size: 1rem;
            margin-bottom: 4px;
        }

        .timeline-desc {
            font-size: 0.87rem;
            color: #6b7d93;
            line-height: 1.6;
            margin: 0;
        }

        /* TEAM CARDS */
        .team-card {
            background: white;
            border-radius: 28px;
            overflow: hidden;
            border: 1.5px solid #e4eef8;
            transition: all 0.3s;
            text-align: center;
        }

            .team-card:hover {
                transform: translateY(-10px);
                box-shadow: 0 30px 50px -15px #0a3a6e30;
                border-color: #b3d0f0;
            }

        .team-img-wrap {
            height: 220px;
            overflow: hidden;
            background: linear-gradient(135deg, #e8f2ff, #d0e4f7);
            display: flex;
            align-items: center;
            justify-content: center;
            position: relative;
        }

            .team-img-wrap img {
                width: 100%;
                height: 100%;
                object-fit: cover;
                object-position: top;
                transition: transform 0.4s;
            }

        .team-card:hover .team-img-wrap img {
            transform: scale(1.06);
        }

        .team-avatar-fallback {
            width: 90px;
            height: 90px;
            border-radius: 50%;
            background: #0b2a4e;
            display: flex;
            align-items: center;
            justify-content: center;
            font-size: 2.2rem;
            font-weight: 800;
            color: #7ab8f5;
            letter-spacing: 0.02em;
        }

        .team-info {
            padding: 1.4rem 1.2rem 1.6rem;
        }

        .team-name {
            font-weight: 700;
            color: #0b1c2e;
            font-size: 1.05rem;
            margin-bottom: 3px;
        }

        .team-role {
            font-size: 0.82rem;
            font-weight: 600;
            color: #2266bb;
            margin-bottom: 10px;
        }

        .team-bio {
            font-size: 0.83rem;
            color: #6b7d93;
            line-height: 1.6;
            margin-bottom: 12px;
        }

        .team-socials a {
            display: inline-flex;
            align-items: center;
            justify-content: center;
            width: 34px;
            height: 34px;
            border-radius: 50%;
            background: #eaf2ff;
            color: #1a5096;
            font-size: 0.85rem;
            margin: 0 3px;
            text-decoration: none;
            transition: all 0.2s;
        }

            .team-socials a:hover {
                background: #0b2a4e;
                color: white;
                transform: scale(1.1);
            }

        /* WHY CHOOSE US */
        .why-section {
            background: #0b2a4e;
            border-radius: 40px;
            padding: 4rem 3rem;
            position: relative;
            overflow: hidden;
        }

            .why-section::before {
                content: '';
                position: absolute;
                width: 400px;
                height: 400px;
                background: rgba(255,255,255,0.03);
                border-radius: 50%;
                top: -150px;
                right: -100px;
            }

            .why-section::after {
                content: '';
                position: absolute;
                width: 250px;
                height: 250px;
                background: rgba(255,255,255,0.03);
                border-radius: 50%;
                bottom: -80px;
                left: 40px;
            }

        .why-item {
            display: flex;
            align-items: flex-start;
            gap: 18px;
            margin-bottom: 2rem;
        }

            .why-item:last-child {
                margin-bottom: 0;
            }

        .why-num {
            min-width: 50px;
            height: 50px;
            border-radius: 14px;
            background: rgba(255,255,255,0.08);
            border: 1px solid rgba(255,255,255,0.12);
            display: flex;
            align-items: center;
            justify-content: center;
            font-size: 1.2rem;
            font-weight: 800;
            color: #7ab8f5;
        }

        .why-item h6 {
            font-weight: 700;
            color: white;
            margin-bottom: 4px;
            font-size: 1rem;
        }

        .why-item p {
            font-size: 0.87rem;
            color: #a0bdd8;
            line-height: 1.6;
            margin: 0;
        }

        /* PARTNERS LOGOS */
        .partner-logo-row {
            display: flex;
            flex-wrap: wrap;
            gap: 14px;
            align-items: center;
        }

        .partner-chip {
            background: white;
            border: 1.5px solid #dceeff;
            border-radius: 50px;
            padding: 10px 22px;
            font-weight: 700;
            font-size: 0.88rem;
            color: #1a4880;
            transition: all 0.2s;
            cursor: default;
        }

            .partner-chip:hover {
                background: #0b2a4e;
                color: white;
                border-color: #0b2a4e;
                transform: translateY(-3px);
                box-shadow: 0 10px 20px -6px #0b2a4e50;
            }

        /* CERTIFICATIONS */
        .cert-card {
            background: white;
            border-radius: 20px;
            padding: 1.4rem 1.2rem;
            border: 1.5px solid #e4eef8;
            text-align: center;
            transition: all 0.25s;
        }

            .cert-card:hover {
                transform: translateY(-6px);
                box-shadow: 0 22px 36px -12px #0a3a6e22;
                border-color: #b3d0f0;
            }

            .cert-card i {
                font-size: 2.2rem;
                color: #1a5096;
                margin-bottom: 10px;
                display: block;
            }

            .cert-card h6 {
                font-weight: 700;
                color: #0b1c2e;
                font-size: 0.9rem;
                margin-bottom: 4px;
            }

            .cert-card small {
                color: #8ea3ba;
                font-size: 0.78rem;
            }

        /* CTA BANNER */
        .about-cta {
            background: linear-gradient(135deg, #0b2a4e, #1a5096);
            border-radius: 36px;
            padding: 3.5rem;
            text-align: center;
            position: relative;
            overflow: hidden;
        }

            .about-cta::before {
                content: '';
                position: absolute;
                width: 350px;
                height: 350px;
                background: rgba(255,255,255,0.04);
                border-radius: 50%;
                top: -120px;
                right: -80px;
            }

        /* RESPONSIVE */
        @@media (max-width: 768px) {
            .about-page-title

        {
            font-size: 2.4rem;
        }

        .why-section {
            padding: 2.5rem 1.5rem;
            border-radius: 28px;
        }

        .about-cta {
            padding: 2.5rem 1.5rem;
            border-radius: 24px;
        }

        .stat-float-grid {
            grid-template-columns: 1fr 1fr;
        }

        }
    </style>
 

<!-- ══════════════════════════════════════════════════
     HERO
══════════════════════════════════════════════════ -->
<section class="about-hero">
    <div class="container position-relative" style="z-index:5;">
        <div class="row align-items-center g-5">

            <!-- Left text -->
            <div class="col-lg-6" data-aos="fade-up">
                <span class="about-section-label"><i class="fas fa-building me-1"></i>About Us</span>
                <h1 class="about-page-title">We are Duha<br>Global Technology</h1>
                <p class="fs-5 text-secondary mt-3 mb-4" style="line-height:1.75;">
                    Born in Dhaka, built for the world. Since 2018 we have been delivering premium mobile accessories, intelligent security systems, and e‑commerce solutions that empower people and businesses across 12+ countries.
                </p>
                <div class="d-flex flex-wrap gap-3">
                    <a href="#our-story" class="btn btn-duha"><i class="fas fa-book-open me-2"></i>Our Story</a>
                    <a href="#contact" class="btn btn-outline-primary rounded-pill px-4 py-3 fw-bold"><i class="fas fa-phone-alt me-2"></i>Get in Touch</a>
                </div>
            </div>

            <!-- Right: image + floating stats -->
            <div class="col-lg-6" data-aos="zoom-in-left">
                <div class="row g-3">
                    <div class="col-8">
                        <div class="about-hero-img">
                            <img src="https://images.pexels.com/photos/3184291/pexels-photo-3184291.jpeg?auto=compress&cs=tinysrgb&w=800" alt="Duha Global Team" onerror="this.style.height='380px';this.style.background='#eaf2ff';" />
                            <div class="img-overlay-badge">
                                <i class="fas fa-map-marker-alt me-2 text-warning"></i>Dhaka, Bangladesh
                            </div>
                        </div>
                    </div>
                    <div class="col-4">
                        <div class="stat-float-grid" style="grid-template-columns:1fr;">
                            <div class="stat-float-card" data-aos="fade-left" data-aos-delay="100">
                                <div class="stat-icon"><i class="fas fa-calendar-alt"></i></div>
                                <div class="stat-num">2018</div>
                                <div class="stat-lbl">Founded</div>
                            </div>
                            <div class="stat-float-card" data-aos="fade-left" data-aos-delay="200">
                                <div class="stat-icon"><i class="fas fa-globe"></i></div>
                                <div class="stat-num">12+</div>
                                <div class="stat-lbl">Countries</div>
                            </div>
                            <div class="stat-float-card" data-aos="fade-left" data-aos-delay="300">
                                <div class="stat-icon"><i class="fas fa-users"></i></div>
                                <div class="stat-num">50K+</div>
                                <div class="stat-lbl">Customers</div>
                            </div>
                        </div>
                    </div>
                </div>
            </div>

        </div>
    </div>
</section>

<!-- ══════════════════════════════════════════════════
     QUICK STATS ROW
══════════════════════════════════════════════════ -->
<section class="container py-5">
    <div class="row g-3 text-center" data-aos="fade-up">
        <div class="col-6 col-md-3">
            <div class="stat-float-card">
                <div class="stat-icon"><i class="fas fa-box-open"></i></div>
                <div class="stat-num">120+</div>
                <div class="stat-lbl">Products</div>
            </div>
        </div>
        <div class="col-6 col-md-3">
            <div class="stat-float-card">
                <div class="stat-icon"><i class="fas fa-handshake"></i></div>
                <div class="stat-num">300+</div>
                <div class="stat-lbl">Dealer Partners</div>
            </div>
        </div>
        <div class="col-6 col-md-3">
            <div class="stat-float-card">
                <div class="stat-icon"><i class="fas fa-star"></i></div>
                <div class="stat-num">4.8★</div>
                <div class="stat-lbl">Avg Rating</div>
            </div>
        </div>
        <div class="col-6 col-md-3">
            <div class="stat-float-card">
                <div class="stat-icon"><i class="fas fa-shield-alt"></i></div>
                <div class="stat-num">2 yr</div>
                <div class="stat-lbl">Warranty</div>
            </div>
        </div>
    </div>
</section>

<hr class="section-divider">

<!-- ══════════════════════════════════════════════════
     OUR STORY + TIMELINE
══════════════════════════════════════════════════ -->
<section id="our-story" class="container py-5">
    <div class="row align-items-center g-5">

        <!-- Timeline -->
        <div class="col-lg-6" data-aos="fade-right">
            <span class="about-section-label"><i class="fas fa-history me-1"></i>Our Journey</span>
            <h2 class="section-title mb-4">From a small shop<br>to a global brand</h2>
            <div class="timeline">

                <div class="timeline-item">
                    <div class="timeline-dot"></div>
                    <div class="timeline-year">2018</div>
                    <div class="timeline-title">The beginning — mobile retail</div>
                    <p class="timeline-desc">Started as a small mobile accessories shop in Dhaka with a vision to bring quality products to Bangladeshi consumers at fair prices.</p>
                </div>

                <div class="timeline-item">
                    <div class="timeline-dot"></div>
                    <div class="timeline-year">2019</div>
                    <div class="timeline-title">GaN charger line launched</div>
                    <p class="timeline-desc">Introduced our first branded GaN fast charger range — quickly becoming one of Bangladesh's top-selling charger brands.</p>
                </div>

                <div class="timeline-item">
                    <div class="timeline-dot"></div>
                    <div class="timeline-year">2021</div>
                    <div class="timeline-title">CCTV & security division</div>
                    <p class="timeline-desc">Expanded into CCTV cameras, NVR kits, and surveillance solutions for homes, offices, and industrial clients.</p>
                </div>

                <div class="timeline-item">
                    <div class="timeline-dot"></div>
                    <div class="timeline-year">2022</div>
                    <div class="timeline-title">E-commerce arm launched</div>
                    <p class="timeline-desc">Built a full-service e-commerce wing supporting sellers on Amazon, Shopify, Daraz, and local platforms with sourcing, photography, and fulfillment.</p>
                </div>

                <div class="timeline-item">
                    <div class="timeline-dot"></div>
                    <div class="timeline-year">2024</div>
                    <div class="timeline-title">International expansion</div>
                    <p class="timeline-desc">Began serving clients in 12+ countries. Export partnerships established across South Asia, Middle East, and Europe.</p>
                </div>

                <div class="timeline-item">
                    <div class="timeline-dot"></div>
                    <div class="timeline-year">2026 →</div>
                    <div class="timeline-title">The next chapter</div>
                    <p class="timeline-desc">Expanding product lines, opening regional offices, and launching our own proprietary tech accessories sub-brand.</p>
                </div>

            </div>
        </div>

        <!-- Story image -->
        <div class="col-lg-6" data-aos="fade-left">
            <div class="about-hero-img mb-4">
                <img src="https://images.pexels.com/photos/3184325/pexels-photo-3184325.jpeg?auto=compress&cs=tinysrgb&w=800" alt="Duha Global office" />
                <div class="img-overlay-badge"><i class="fas fa-quote-left me-2 text-warning"></i>Innovation & Integrity — CEO</div>
            </div>
            <div class="bg-white rounded-4 p-4 border border-2" style="border-color:#dceeff !important;">
                <p class="fs-5 fst-italic text-secondary mb-3" style="line-height:1.75;">
                    "We started Duha with one goal — give people access to products that just <strong>work</strong>. No compromise on quality, no compromise on service."
                </p>
                <div class="d-flex align-items-center gap-3">
                    <div style="width:48px;height:48px;border-radius:50%;background:#0b2a4e;display:flex;align-items:center;justify-content:center;font-weight:800;color:#7ab8f5;font-size:1.1rem;">MR</div>
                    <div>
                        <div class="fw-bold text-dark">Md. Rahman</div>
                        <div class="text-muted small">Founder & CEO, Duha Global Technology</div>
                    </div>
                </div>
            </div>
        </div>

    </div>
</section>

<hr class="section-divider">

<!-- ══════════════════════════════════════════════════
     VISION & MISSION (detailed)
══════════════════════════════════════════════════ -->
<section class="container py-5">
    <div class="text-center mb-5" data-aos="fade-up">
        <span class="about-section-label"><i class="fas fa-flag-checkered me-1"></i>Our Compass</span>
        <h2 class="section-title">Vision & Mission</h2>
        <p class="fs-5 text-secondary">The principles that guide every decision we make.</p>
    </div>
    <div class="row g-4">
        <div class="col-md-6" data-aos="fade-right">
            <div class="bg-white rounded-5 p-5 h-100 border" style="border-color:#dceeff !important; border-width:1.5px !important;">
                <div style="width:70px;height:70px;border-radius:22px;background:#eaf2ff;display:flex;align-items:center;justify-content:center;margin-bottom:1.5rem;">
                    <i class="fas fa-binoculars fa-2x" style="color:#1a5096;"></i>
                </div>
                <h3 class="fw-bold mb-3">🌍 Our Vision</h3>
                <p class="fs-5" style="color:#4a6380;line-height:1.8;">
                    To be the most trusted global technology partner in mobile accessories, security solutions, and digital commerce — connecting Bangladesh's innovation with the world.
                </p>
                <hr style="border-color:#dceeff;">
                <ul class="list-unstyled mt-3 mb-0">
                    <li class="mb-2"><i class="fas fa-arrow-right text-primary me-2"></i> Global reach with local heart</li>
                    <li class="mb-2"><i class="fas fa-arrow-right text-primary me-2"></i> Technology that empowers lives</li>
                    <li>       <i class="fas fa-arrow-right text-primary me-2"></i> Trusted partner for 100+ countries by 2030</li>
                </ul>
            </div>
        </div>
